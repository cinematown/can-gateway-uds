CM_ "Generated from VW PQ35_46 ACAN KMatrix V5.20.6F, 2016-05-30.";
CM_ SG_ 1827 NMH_ABS_Start_1 "Zustand Start (<--Sleep)";
CM_ SG_ 1827 NMH_ABS_Start_2 "Zustand Start (<--Prepare to Sleep)";
CM_ SG_ 1827 NMH_ABS_Normal_Mode_1 "Zustand Normal Mode (<-- Start)";
CM_ SG_ 1827 NMH_ABS_Normal_Mode_2 "Zustand Normal Mode (<-- Ready to Sleep)";
CM_ SG_ 1827 NMH_ABS_Per_WakeUp "Weckurasche Peripherie | 0 = wenn Funktionswakeup | 1 = CAN | 2 = P-Wakeup, Ursache nicht bekannt | 3 = KL 15 HW (falls vorhanden)";
CM_ SG_ 1827 NMH_ABS_Fkt_WakeUp "\"Weckursache Funktion\" | 0 = wenn Peripheriewakeup";
CM_ SG_ 1827 NMH_ABS_NM_aktiv_Klemme_15 "NM-Nachlaufursache, nicht \"Ready To Sleep\" | 1 = Klemme 15 ein";
CM_ SG_ 1827 NMH_ABS_NM_aktiv_Diagnose "NM-Nachlaufursache, nicht \"Ready To Sleep\" | 1 = Diagnose bei Kl 15 aus";
CM_ SG_ 1827 NMH_ABS_NM_aktiv_Start "NM-Nachlaufursache, nicht \"Ready To Sleep\" | 1 = Mindestaktivzeit Zustand \"Start\"";
CM_ SG_ 1827 NMH_ABS_NL_aktiv_4 "Nachlaufursache 4 | 1 = kein Stillstand aller Raeder erkannt";
CM_ SG_ 1827 NMH_ABS_TimeOut_Fehler "1 = Timeout Fehlerspeichereintrag";
CM_ SG_ 1827 NMH_ABS_CAN_Diag_deaktiv "1 = Keine CAN Bus bezogene Eigendiagnose";
CM_ SG_ 1827 NMH_ABS_KompSchutz "1 = Funktionseinschraenkung aufgrund Komponentenschutz / WFS aktiv";
CM_ SG_ 1827 NMH_ABS_Mute_Mode "1 = Funktionseinschraenkung aufgrund Mute Mode aktiv, nur VW";
CM_ SG_ 1827 NMH_ABS_Transport_Mode "1 = Funktionseinschraenkung aufgrund Transport Mode aktiv";
CM_ SG_ 1827 NMH_ABS_Abschaltstufe_aktiv "1 = Funktionsabschaltung wegen Abschaltstufe";
CM_ SG_ 1827 NMH_ABS_Eindraht_Fehler "1 = Eindrahtbetrieb erkannt";
CM_ SG_ 1827 NMH_ABS_Car_WakeUp "Car WakeUp optional";
CM_ SG_ 1827 NMH_ABS_NL_aktiv_5 "Nachlaufursache 5";
CM_ SG_ 1827 NMH_ABS_NL_aktiv_6 "Nachlaufursache 6";
CM_ SG_ 1827 NMH_ABS_NL_aktiv_7 "Nachlaufursache 7";
CM_ SG_ 1827 NMH_ABS_NL_aktiv_8 "Nachlaufursache 8";
CM_ SG_ 1827 NMH_ABS_NL_0 "Nachlauf 0";
CM_ SG_ 1827 NMH_ABS_NL_1 "Nachlauf 1";
CM_ SG_ 1827 NMH_ABS_NL_2 "Nachlauf 2";
CM_ SG_ 1827 NMH_ABS_NL_3 "Nachlauf 3";
CM_ SG_ 1827 NMH_ABS_NL_4 "Nachlauf 4";
CM_ SG_ 1827 NMH_ABS_NL_5 "Nachlauf 5";
CM_ SG_ 1827 NMH_ABS_NL_6 "Nachlauf 6";
CM_ SG_ 1827 NMH_ABS_NL_7 "Nachlauf 7";
CM_ SG_ 768 TPDyn_Diag_1_1 "Tester | TP 2.0 Empfangskanal 1 fuer Tester";
CM_ SG_ 769 TPDyn_Diag_1_2 "Tester | TP 2.0 Empfangskanal 2 fuer Tester";
CM_ SG_ 770 TPDyn_Diag_1_3 "Tester | TP 2.0 Empfangskanal 3 fuer Tester";
CM_ SG_ 771 TPDyn_Diag_1_4 "Tester | TP 2.0 Empfangskanal 4 fuer Tester";
CM_ SG_ 772 TPDyn_Diag_1_5 "Tester | TP 2.0 Empfangskanal 5 fuer Tester";
CM_ SG_ 773 TPDyn_Diag_1_6 "Tester | TP 2.0 Empfangskanal 6 fuer Tester";
CM_ SG_ 774 TPDyn_Diag_1_7 "Tester | TP 2.0 Empfangskanal 7 fuer Tester";
CM_ SG_ 775 TPDyn_Diag_1_8 "Tester | TP 2.0 Empfangskanal 8 fuer Tester";
CM_ SG_ 515 ABS_TP_Er "TP 2.0 Eroeffnungskanal";
CM_ SG_ 1440 BR2_Blinkmode "Bremskontroll-Lampe soll im Warnfall mit 1Hz blinken, wenn das Bit gesetzt ist (z. Zt. nur bei VW) (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Querbeschl "Wenn BR2_Querb_Zahn = 0: errechnete Groesse (bei ABS-Systemen) zur Kurvenfahrterkennung fuer das Getriebe, oder gemessener Sensorwert (sieheBR2_Sta_Quer) (im PQ35 kein Rohwert). Bei Linkskurve positives Vorzeichen. | Achtung: Die Guete bei errechneten Groessen (z. B. bei MK70 neu) kann situationsbedingt sehr schlecht sein! | | ESC-Systeme: 0xFF bedeutet Querbeschleunigungs-Sensor defekt. | | ABS-Systeme: 0x7F (= Initwert entspricht physikalisch 0 g, mit gesetztem Q-Bit) die Groesse kann fahrsituationsbedingt nicht berechnet werden (z. b. ABS-Regelung, v < X km/h) / | 0xFF (mit gesetztem Q-Bit) bedeutet hier die Groesse kann aufgrund im System vorliegender Fehler nicht berechnet werden. | Hinweis: ABS TRW EBC460 sendet noch bis KW22/14 0xFF, wenn die Groesse fahrsituationsbedingt nicht berechnet werden kann.";
CM_ SG_ 1440 BR2_Zahnzahl "Wenn Byte 2, Bit 0 = 1: Zaehnezahl des verwendeten Impulsrades";
CM_ SG_ 1440 BR2_Querb_Zahn "Byte 1 hat in der Hochlaufphase (Boschsystem: ca. 2s, Contisystem: ca. 1,7s) eine alternative Bedeutung: Zaehnezahl der Impulsraeder werden uebertragen | Querbeschl./Zaehnezahl";
CM_ SG_ 1440 BR2_mi_Radgeschw "Radumdrehungen / Sekunde sind Eingangsgroesse fuer die Geschwindigkeitsberechnung im Kombi; es wird der Mittelwert der permanent angetriebenen Raeder (alle ausser Audi B6/D3) ausgegeben oder bei Audi B6/D3 die Geschwindigkeit des linken Vorderrades; im Kombi wird aus dieser Raddrehzahl und dem Radumfang die Fahrzeuggeschwindigkeit errechnet | RPU: 4*2 Mittelwert HA , 4*4 zuschaltbar (starr) Mittelwert der HA , 4*4 Torsen Mittelwert aller Raeder | T5GP: 4*2 Mittelwert VA, 4*4 Haldex Mittelwert VA;;Konstanten: | V_INIT = 7FC4H (bzw. FF88H oder FF89H = 1111 1111 1000 100x B in 2-Byte-Schreibweise) (entspricht 65416 1/s) | V_Uspg = 7FD5H (bzw. FFAAH oder FFABH = 1111 1111 1010 101x B in 2-Byte-Schreibweise) (entspricht 65450 1/s) | V_Fehler = 7FE6H (bzw. FFCCH oder FFCDH = 1111 1111 1100 110x B in 2-Byte-Schreibweise) (entspricht 65484 1/s) | mittlere Raddrehzahl (Bremse 2)";
CM_ SG_ 1440 BR2_Lampe_ABS "Sicherheitswarnlampe, siehe Bremse_1 Byte 2, Bit 0 (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Lampe_ASR "Zustand der Lampe wird auf dem CAN-Bus ausgegeben (auch Blinkinformation) | Fahrzeuge mit ASR/ESP/MABS-Funktionalitaet bedienen die Sicherheitswarnlampe | Init: 0 (ABS)/1 (ASR/ESP SILA), siehe Bremse_1 Byte 2, Bit 1 (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Lampe_BK "(Blinktakt wird nur bei Audi wie bisher vom Kombi generiert) | Separate Bremskontroll-Lampe (Audi ab D3/C6) wird als Sicherheitswarnlampe aufgeprueft (Initwert 1) | Kombinierte Bremskontroll-Lampe (VW) wird aufgeprueft, siehe Bremse_1 Byte 2, Bit 2 Zustand der Lampe wird auf dem CAN-Bus ausgegeben (auch Blinkinformation) | Fahrzeuge mit ASR/ESP/MABS-Funktionalitaet bedienen die Sicherheitswarnlampe | Init: 0 (ABS)/1 (ASR/ESP SILA), siehe Bremse_1 Byte 2, Bit 1 (nicht D1GP/BY61x/MK70 alt) | Bremskontroll-Lampe";
CM_ SG_ 1440 BR2_Lampe_RKA "Reifen-Kontroll-Anzeige (indirekt messende Reifendruckueberwachung): siehe Bremse_4 Byte 4, Bit 0 Zustand der Lampe wird auf dem CAN-Bus ausgegeben (auch Blinkinformation) | Fahrzeuge mit ASR/ESP/MABS-Funktionalitaet bedienen die Sicherheitswarnlampe | Init: 0 (ABS)/1 (ASR/ESP SILA), siehe Bremse_1 Byte 2, Bit 1 (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Zaehler "Ueberlaufender Zaehler (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Text "0 Kein Text | 1 \"ESP Stoerung\" | 2 \"ABS Stoerung\" | 3 \"ESP/ABS Stoerung\" | 4 \"Werkstatt Bremse\" | 5 \"ASR Stoerung\" | 6 \"ESP Deaktiviert\", nur Audi A1 \"ESP SPORT\" | 7 \"ASR Deaktiviert\", nur Audi A1 \"ESP OFF\", Q3 \"ESP OFFROAD\" | 8 \"ESP Aktiviert\" | 9 \"Stoerung Hillholder\" (PQ46) \"Anfahrhilfe Fehler Werkstatt\" (T5GP) | 10 \"Keine Bremskraftverstaerkung\" | 11 \"ASR aktiviert\" | 12 \"ABS/ASR Stoerung\" | 13 \"Bitte Reifen pruefen\" | 14 \"ESP Sport\", nur Audi Q3 \"ESP OFF\" | 15 Reserviert | (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Aku_Warn "1: Bremse steuert den Gong im Kombi ein Mal an (keine Akustik bei VW) | 2: Bremse steuert den Gong (Summer bei VW) im Kombi drei Mal an, z. Zt. nur in Kombination mit Text \"Werkstatt Bremse\" (Ausfall der EBV) | 3: Summeransteuerung ist durch Kombi auf 1 Sekunde festgelegt. Ausloesung durch 0 -> 1 Flanke. (bei VW: gelbe Warnung) | (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_HDC_aktiv "Die Funktion Bergabfahrassistent ist bei gesetztem Bit aktiv oder standby. | Das Motor SG nutzt Info zum Umschalten der GRA Funktion. | Das DQ-Getriebe nutzt die Info zur Kupplungsansteuerung. | | VW316/RPU: Bit=1 heisst HDC Standby oder aktiv | VW472 Cross: Bit=1, wenn HDC-Bremseneingriff aktiv | (nicht D1GP/BY61x/MK70 alt)";
CM_ SG_ 1440 BR2_Wegimpulse "Anzahl der Raddrehzahlimpulse (steigende und fallende Flanke) der Vorderachse (gemittelt) zur Wegstreckenzaehlung | bei Ausfall eines Drehzahlfuehlers wird der funktionsfaehige Sensor zur Ausgabe verwendet | Wegimpulse Vorderachse | | Im RPU wird die Hinterachse zur Ermittlung der Wegimpulse verwendet!";
CM_ SG_ 1440 BR2_Ueberl_Imp "der Wegimpuls-Zaehler ist mindestens einmal uebergelaufen (Reset des ABS-Steuergeraetes) kann damit erkannt werden | Wegimpulszaehlerstatus";
CM_ SG_ 1440 BR2_Fehlereintr "Bei gesetztem Bit ist mindestens ein Kundendienstfehler eingetragen";
CM_ SG_ 1440 BR2_LampeHDC "VW316/VW472 Cross: Funktionslampe Bergabfahrassistent (HDC) | Lampe ist an bei HDC im standby und blinkt mit 3,3 Hz bei aktiver Funktion. | Das DQ-Getriebe nutzt die Info zur Kupplungsansteuerung. | | RPU: Funktionslampe Bergabfahrassistent und Offroad-ABS | MK25A-ESP: Lampe ist an bei HDC im standby und blinkt mit 3,3 Hz bei aktiver Funktion (jeweils bis 30 km/h). | Oberhalb von 30 km/h leuchtet die Lampe dauerhaft (ab KW15/10). | MK25E-ABS: Funktionslampe Offroad-ABS | Lampe leuchtet dauerhaft (ab KW15/10) | | (ACHTUNG: war Lampe Reifendruckwarnung RB im PQ24)";
CM_ SG_ 1440 BR2_QB_Querbeschl "Definition nach CAN-Lastenheft | Hinweis zu CT-ESP: Bit wird auch gesetzt, wenn Querbeschl. bei ESP errechnet statt gemessen wird (nicht Colorado/Colorado GP, nicht D1GP/BY61x) | (ACHTUNG: war Summer Reifendruckwarnung RB im PQ24 und \"Status Bremsassistent\" im T5)";
CM_ SG_ 1440 BR2_Sta_Imp "Fehler wird gesetzt, wenn beide ABS-Drehzahlfuehler an der Vorderachse defekt sind | Fehlerstatus Wegimpulse | | Im RPU wird die Hinterachse zur Ermittlung der Wegimpulse verwendet!";
CM_ SG_ 1440 BR2_Impulszahl "Zaehnezahl des verwendeten Impulsrades";
CM_ SG_ 1440 BR2_SleepInd "Die Sleep-Bereitschaft wird nach Klemme 15 aus durch Setzen dieses Bits signalisiert (nicht VW D1/Colorado, nicht D1GP/BY61x, nicht RB PQ25) | NMHigh-Teilnehmer der PQ35/46 muessen das Signal nach Kl.-15 aus weiterhin bedienen oder dauerhaft auf 1 = 'Sleep bereit' setzen!";
CM_ SG_ 1440 BR2_Sta_Quer "Querbeschleunigung in Byte 1 wird errechnet oder beim ESP gemessen";
CM_ SG_ 416 BR1_ASR_Anf "Anforderungen in Byte 5 und 6 sind auszufuehren";
CM_ SG_ 416 BR1_MSR_Anf "Anforderung in Byte 7 ist auszufuehren; Byte 6 aendert seine Bedeutung, wenn dieses Bit gesetzt ist | MSR Anforderung";
CM_ SG_ 416 BR1_ABS_Brems "Antiblockiersystem, Bit zeigt auch Druckabbau an (z.B. ESP hat zuviel Druck aufgebaut oder ungebremste Regelung auf Bahnuebergang)";
CM_ SG_ 416 BR1_EDS_Eingr "Elektronische Differentialsperre | EDS Eingriff";
CM_ SG_ 416 BR1_ESP_Eingr "Fahrdynamikregelung | ESP Eingriff";
CM_ SG_ 416 BR1_ASR_Eingr "Wunsch an das Getriebe waehrend einer ASR Regelung, bei Audi nur 00 und 01 genutzt | ASR-Schaltbeeinflussung";
CM_ SG_ 416 BR1_EBV_Eingr "Elektronische Bremskraftverteilung, aktueller Eingriff (Druckhalten, Druckabbau), kein ABS / ESP-Eingriff | EBV Eingriff";
CM_ SG_ 416 BR1_Lampe_ABS "Sicherheitswarnlampe | Lampe ABS";
CM_ SG_ 416 BR1_Lampe_ASR "Zustand der Lampe wird auf dem CAN-Bus ausgegeben (auch Blinkinformation) | Fahrzeuge mit ASR/ESP/MABS-Funktionalitaet bedienen die Sicherheitswarnlampe | Init: 0/1(SILA) | Lampe ASR / ESP";
CM_ SG_ 416 BR1_Lampe_BK "rote Lampe wird angesteuert, z. B. bei EBV-Ausfall;(Sicherheitswarnlampe im Audi C6/D3, AU716 mit Initwert 1) | Bremskontroll-Lampe";
CM_ SG_ 416 BR1_Lichtschalt "ohne aktiven BKV wird hier der Bremslichtschalter (0 kein Bremsen, 1 Bremse betaetigt) uebertragen (ESP5.7, ESP 8, Mk60, T5GP/RPU(MK25A XT)) | ab PQ46 (mit Einsatz des einkanaligen Hall-BLS): Fahrer hat durch Pedalbetaetigung die Bremsdruckschwelle ueberschritten (nicht ACC oder EPB-Bremsung) | Im Colorado: Info wird erkannt, wenn der Fahrer einen aktiven BKV uebertritt (Loeseschalterinformation plus Plausibilitaet) | Nur im Porsche Cayenne wird das Bit auch bei Gespannstabilisierungseingriff gesetzt. | Bremslichtschalter / Bremsdruckschwelle ueberschritten";
CM_ SG_ 416 BR1_StaDruckschw "beim Bosch-ABS wird der Bremstestschalter (0 kein Bremsen, 1 Bremse betaetigt) uebertragen (D1GP/BY61x u. T5GP/RPU(MK25A XT) | ab PQ46: Druckschwelleninformation (Byte 2, Bit 3) kann noch nicht oder aufgrund eines Fehlers nicht ausgegeben werden (nicht Colorado) | Bei einem aktiven BKV wird im angesteuerten Zustand (z.B. bei ESP-Eingriff oder ADR-Bremsung) ohne Beeinflussung des Fahrers das Bremspedal betaetigt. In Byte 2, Bit 3 ist ersichtlich, ob der Fahrer den aktiven BKV uebertritt (im Colorado/T5GP). | Bremstestschalter / Druckschwellenstatus nicht verfuegbar / Status aktiver BKV";
CM_ SG_ 416 BR1_Diagnose "Kombi unterdrueckt z.B. den Gong | ABS-Diagnose";
CM_ SG_ 416 BR1_Rad_kmh "Low Byte 3, High Byte 4 (Aufloesung 1,28 km/h) | Bremse holt sich den Radumfang aus der Botschaft 'Kombi_3' | generell wird Mittelwert (alle ausser B6/D3) der permanent angetriebenen Raeder ausgegeben (d.h. bei Frontantrieb und gesteuertem Allrad (Haldex) Mittelwert der Vorderraeder, bei Allrad Mittelwert der 4 Raeder) oder bei Audi B6/D3 die Geschwindigkeit des linken Vorderrades, bei MSR oder ABS Eingriffen wird die ABS-Referenzgeschwindigkeit fuer >=200 msec eingespiegelt (Zeit wird mit Aktiv-Flanke getriggert). Beim Sensorfehler ist im ABS-SG ein Fehler gespeichert; Contiteves liefert sofort gueltige Werte | | RPU: 4*2 Mittelwert HA , 4*4 zuschaltbar (starr) Mittelwert der HA , 4*4 Torsen Mittelwert aller Raeder | T5GP: 4*2 Mittelwert VA, 4*4 Haldex Mittelwert VA | | Konstanten: | V_INIT = 7FC4H (bzw. FF88H oder FF89H = 1111 1111 1000 100x B in 2-Byte-Schreibweise) (entspricht 327,08 km/h) (nicht Colorado, D1GP/BY61x) | V_Uspg = 7FD5H (bzw. FFAAH oder FFABH = 1111 1111 1010 101x B in 2-Byte-Schreibweise) (entspricht 327,25 km/h) (nicht D1GP/BY61x) | V_Fehler = 7FE6H (bzw. FFCCH oder FFCDH = 1111 1111 1100 110x B in 2-Byte-Schreibweise) (entspricht 327,42 km/h) (nicht D1GP/BY61x) | Geschwindigkeit (Bremse 1)";
CM_ SG_ 416 BR1_ASRMo_fa "falls Byte 1, Bit 1 gleich 0;Achtung: Fehlerwert FFH wird nur benutzt, wenn es ein ASR-Eingriffsmoment ist - nicht beim bitinvertierten MSR-Moment;Hinweis T5GP/RPU: Bei zweikanaliger Anforderung muss Bremsensteuergeraet die Zuendwinkelreserve aus mMotor_2 Byte 8 auswerten. | | Hybrid: Interpretiert als Reduktion Summenmoment VM+EM | ASR Eingriffsmoment schnell";
CM_ SG_ 416 BR1_MSR_Mo_inv "falls Byte 1, Bit 1 gleich 1 | inverses MSR Eingriffsmoment";
CM_ SG_ 416 BR1_MSR_Mo "Hybrid: Interpretiert als Summenmoment VM+EM | MSR Eingriffsmoment";
CM_ SG_ 416 BR1_Zaehler "ueberlaufender Botschaftszaehler, um Eingriffsmoment als aktualisiert zu kennzeichnen | Zaehler (Bremse 1)";
CM_ SG_ 416 BR1_ASR_ESP "Kombi kann ggfs. die Lampe ansteuern | ASR/ESP-Steuergeraet";
CM_ SG_ 416 BR1_ESPASR_passiv "ESP oder ASR (oder beides, oder Teilfunktionen, solange Fahrer nicht bremst) vom Fahrer passiv getastet oder ASR/ESP Funktionsumschaltung oder ueber Rollenmodus deaktiviert";
CM_ SG_ 416 BR1_Sta_ESP "Steht fuer Stilllegung ESP mit Fehlerspeichereintrag. | Wird in TRW-Projekten auch im Rollenmodus und waehrend Nachlauf gesetzt.";
CM_ SG_ 416 BR1_Ersatz_Kmh "Geschwindigkeit wird als Ersatzwert ausgegeben (z.B. ein Sensor defekt, kein Radumfang gelernt, kein oder fehlerhafter Radumfang vom Kombi empfangen oder bei Contiteves und passiven Sensoren wird Hinterrad eingespiegelt) | Geschwindigkeits-Ersatzwert";
CM_ SG_ 416 BR1_MAD "OBD-Funktion (MAD-Signal), wird bei Teves / TRW z.Zt. nicht ausgegeben | Schlechtwegausblendung";
CM_ SG_ 416 BR1_Sta_MAD "ESP 5.7: Im ESP-Fehlerfall ist Bit \"ungueltig\" | ESP 8: Im ESP-Fehler ist Bit weiterhin \"gueltig\" | Initwert \"0\" wird gesendet, wenn Funktion umgesetzt | Initwert \"1\" wird gesendet, wenn Funktion nicht umgesetzt | Fehlerstatus Schlechtwegausblendung";
CM_ SG_ 416 BR1_BKV_aktiv "neues Status-Bit zur Vermeidung von Problemen waehrend der Uebergangszeit auf die neue Definition (BKV) und zur Darstellung des Fehlerzustandes: nur noch in T5 und im Colorado | Aktiver Bremskraftverstaerker";
CM_ SG_ 416 BR1_ASRMo_sl "wird in TRW Projekten nicht bedient (es wird 0 gesendet) | | Hybrid: | Interpretiert als Reduktion Summenmoment VM+EM | ASR Eingriffsmoment langsam";
